# Stripe billing — required for the subscription/payment system.
# Copy these into .env.local (which is git-ignored) and fill in real values.
# See .env.local.example for the app's full set of environment variables.

# Stripe Dashboard → Developers → API keys (Secret key). sk_test_… in dev, sk_live_… in prod.
STRIPE_SECRET_KEY=sk_test_...

# Signing secret from the webhook endpoint you register
# (Developers → Webhooks → endpoint → Signing secret). Starts with whsec_…
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring monthly Price IDs for the two paid plans:
#   STRIPE_CORE_PRICE_ID → Core Premium ($20/month)
#   STRIPE_FULL_PRICE_ID → Full Premium ($50/month)
STRIPE_CORE_PRICE_ID=price_...
STRIPE_FULL_PRICE_ID=price_...

# Public base URL of the app — used for Stripe Checkout success/cancel redirects.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
