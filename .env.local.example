# Supabase — from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — powers every app-wide AI feature (SEO tips, the SEO & analysis
# chatbots, speech feedback, compare reports, ClipFlow copy) on GPT-4o, plus
# Whisper transcription. This is the only AI key the app needs.
OPENAI_API_KEY=sk-...

# Resend — for access-request emails AND signup verification codes
RESEND_API_KEY=re_...

# Sender for user-facing email (verification codes). Use a VERIFIED domain in
# production — the default resend.dev test sender only delivers to the Resend
# account owner, so real signups won't receive their code.
EMAIL_FROM=Speaker Hub <noreply@yourdomain.com>

# Admin — the email address that can access /admin
ADMIN_EMAIL=mickhatzikostas220@gmail.com

# Signs the one-click approve/deny links in access-request emails. Use a long
# random string (16+ chars), e.g. `openssl rand -hex 32`. If unset, the links
# are omitted from the email and requests must be reviewed in /admin instead.
ADMIN_ACTION_SECRET=

# App URL — used in invite links sent via email, OAuth redirects, and as the
# canonical URL for SEO metadata (sitemap, robots, Open Graph, page canonicals).
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional — override the public marketing/canonical URL if it differs from the
# app URL above (e.g. a custom domain). Falls back to NEXT_PUBLIC_APP_URL.
NEXT_PUBLIC_SITE_URL=

# Stripe — subscription billing (Plans page + checkout)
# STRIPE_SECRET_KEY: from Stripe Dashboard > Developers > API keys.
# STRIPE_WEBHOOK_SECRET: from the webhook endpoint (.../api/subscription/webhook).
# STRIPE_PRICE_*: recurring price IDs. Sandbox defaults are baked into
#   lib/subscription/stripe.ts; override here with your live-mode price IDs.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_CORE=price_...
STRIPE_PRICE_FULL=price_...

# Personal AI Agent ---------------------------------------------------------
# Required for the agent: encrypts users' BYOK API keys + OAuth tokens at rest.
# Use a long random string, e.g. `openssl rand -hex 32`.
APP_ENCRYPTION_KEY=

# Optional — enables the "Connect Google" flow (Google Cloud OAuth client) for
# the agent: Gmail (read/compose/send) + Calendar (read-only). Enable both the
# Gmail API and Google Calendar API on the OAuth client.
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/agent/connect/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Tribe v2 GPU server — leave empty to use mock data
# Deploy tribe-server/main.py to Modal or RunPod, then set this URL
TRIBE_SERVER_URL=
# Optional auth token for your GPU server
TRIBE_SERVER_SECRET=

# Parakeet ASR GPU server (NVIDIA parakeet-tdt-0.6b-v3 on Modal) — used for clip
# transcription in the Studio script editor. Leave empty to fall back to OpenAI Whisper.
# Deploy tribe-server/parakeet-modal.py to Modal, then paste the endpoint URL here.
PARAKEET_SERVER_URL=
# Optional shared secret — must match PARAKEET_SERVER_SECRET in your Modal "parakeet-secret".
PARAKEET_SERVER_SECRET=

# ── ClipFlow ────────────────────────────────────────────────────────────────
# Clip moment-detection, titles, captions, and hashtags run on OpenAI GPT-4o,
# reusing the OPENAI_API_KEY set above — no separate AI key needed.
#
# Bring-your-own keys: every ClipFlow key below (OpenAI, Upload-Post, and the
# per-platform OAuth client id/secret) can also be supplied per-user in the app
# at ClipFlow → "Your API keys" (encrypted at rest with APP_ENCRYPTION_KEY).
# A user's own key always takes precedence over the app-wide value here, so these
# env vars are just the shared defaults / fallback.

# YouTube Data API v3 key — for video/channel metadata lookups.
# Google Cloud Console → APIs & Services → Credentials.
YOUTUBE_API_KEY=

# Encrypts platform OAuth tokens at rest. Use a long random string.
# Falls back to SUPABASE_SERVICE_ROLE_KEY if unset.
CLIPFLOW_TOKEN_SECRET=

# ClipFlow rendering worker — renders the 9:16 MP4 (ffmpeg + yt-dlp) off Vercel,
# which can't run those tools. Deploy tribe-server/clipflow-render-modal.py to
# Modal and paste its URL here. Leave empty to render locally (only works on a
# host that actually has ffmpeg + yt-dlp installed).
CLIPFLOW_RENDER_URL=
# Optional shared secret — must match CLIPFLOW_RENDER_SECRET in your Modal "clipflow-render-secret".
CLIPFLOW_RENDER_SECRET=

# Bearer token for the queue worker route (/api/clipflow/jobs/run), called by a
# scheduled trigger (e.g. Vercel Cron) to publish scheduled posts.
CRON_SECRET=

# ── Publishing via Upload-Post (recommended) ─────────────────────────────────
# Upload-Post (https://upload-post.com) publishes to TikTok, Instagram, YouTube,
# and X under a single account — no separate OAuth app per platform. Set your
# account API key (Upload-Post dashboard → API Keys). Each speaker becomes a
# "profile" under your account and connects THEIR OWN social channels via a
# hosted link in ClipFlow → "Publish accounts" (no key for end users); your
# Upload-Post account billing covers all speakers. Leave unset to fall back to
# the per-platform OAuth apps below.
UPLOAD_POST_API_KEY=
# Optional API base override (default https://api.upload-post.com).
UPLOAD_POST_API_URL=

# Platform OAuth apps — only needed if you are NOT using Postiz above. Fill in
# per platform you want to enable. Until a platform's client id/secret are set,
# its "Connect" button shows "Not configured" instead of failing.
# Redirect URI for each: {NEXT_PUBLIC_APP_URL}/api/clipflow/connections/<platform>/callback
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
TIKTOK_OAUTH_CLIENT_KEY=
TIKTOK_OAUTH_CLIENT_SECRET=
INSTAGRAM_OAUTH_CLIENT_ID=
INSTAGRAM_OAUTH_CLIENT_SECRET=
TWITTER_OAUTH_CLIENT_ID=
TWITTER_OAUTH_CLIENT_SECRET=
