# Supabase — from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — for Whisper transcription and GPT-4o feedback
OPENAI_API_KEY=sk-...

# Resend — for access request approval/rejection emails
RESEND_API_KEY=re_...

# Admin — the email address that can access /admin
ADMIN_EMAIL=mickhatzikostas220@gmail.com

# App URL — used in invite links sent via email and OAuth redirects
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Personal AI Agent ---------------------------------------------------------
# Required for the agent: encrypts users' BYOK API keys + OAuth tokens at rest.
# Use a long random string, e.g. `openssl rand -hex 32`.
APP_ENCRYPTION_KEY=

# Optional — enables the "Connect Gmail" flow (Google Cloud OAuth client).
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/agent/connect/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Tribe v2 GPU server — leave empty to use mock data
# Deploy tribe-server/main.py to Modal or RunPod, then set this URL
TRIBE_SERVER_URL=
# Optional auth token for your GPU server
TRIBE_SERVER_SECRET=

# Parakeet ASR GPU server (NVIDIA parakeet-tdt-0.6b-v3 on Modal) — used for clip
# transcription in the Studio script editor. Leave empty to fall back to OpenAI Whisper.
# Deploy tribe-server/parakeet-modal.py to Modal, then paste the endpoint URL here.
PARAKEET_SERVER_URL=
# Optional shared secret — must match PARAKEET_SERVER_SECRET in your Modal "parakeet-secret".
PARAKEET_SERVER_SECRET=

# ── ClipFlow ────────────────────────────────────────────────────────────────
# Clip moment-detection, titles, captions, and hashtags run on OpenAI GPT-4o,
# reusing the OPENAI_API_KEY set above — no separate AI key needed.

# YouTube Data API v3 key — for video/channel metadata lookups.
# Google Cloud Console → APIs & Services → Credentials.
YOUTUBE_API_KEY=

# Encrypts platform OAuth tokens at rest. Use a long random string.
# Falls back to SUPABASE_SERVICE_ROLE_KEY if unset.
CLIPFLOW_TOKEN_SECRET=

# ClipFlow rendering worker — renders the 9:16 MP4 (ffmpeg + yt-dlp) off Vercel,
# which can't run those tools. Deploy tribe-server/clipflow-render-modal.py to
# Modal and paste its URL here. Leave empty to render locally (only works on a
# host that actually has ffmpeg + yt-dlp installed).
CLIPFLOW_RENDER_URL=
# Optional shared secret — must match CLIPFLOW_RENDER_SECRET in your Modal "clipflow-render-secret".
CLIPFLOW_RENDER_SECRET=

# Bearer token for the queue worker route (/api/clipflow/jobs/run), called by a
# scheduled trigger (e.g. Vercel Cron) to publish scheduled posts.
CRON_SECRET=

# ── Publishing via Postiz (recommended) ──────────────────────────────────────
# Postiz (https://postiz.com) owns the OAuth connection to every platform, so
# publishing through it means no separate OAuth app per platform.
#
# Each speaker connects THEIR OWN Postiz account in the ClipFlow UI (their key is
# stored encrypted per-user), so clips post to their own channels — no env var
# needed for that. The variables below are OPTIONAL and only set an app-wide
# DEFAULT Postiz workspace, used for any user who hasn't connected their own.
# Generate a key in Postiz → Settings → Public API (the same key also powers the
# Postiz MCP server). Requires running supabase/clipflow_postiz.sql.
POSTIZ_API_KEY=
# Self-hosted Postiz only — override the API base for the default key above
# (default https://api.postiz.com/public/v1).
POSTIZ_API_URL=
# Link target for the "Manage in Postiz" button when using the default key
# (default https://app.postiz.com).
POSTIZ_APP_URL=

# Platform OAuth apps — only needed if you are NOT using Postiz above. Fill in
# per platform you want to enable. Until a platform's client id/secret are set,
# its "Connect" button shows "Not configured" instead of failing.
# Redirect URI for each: {NEXT_PUBLIC_APP_URL}/api/clipflow/connections/<platform>/callback
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
TIKTOK_OAUTH_CLIENT_KEY=
TIKTOK_OAUTH_CLIENT_SECRET=
INSTAGRAM_OAUTH_CLIENT_ID=
INSTAGRAM_OAUTH_CLIENT_SECRET=
TWITTER_OAUTH_CLIENT_ID=
TWITTER_OAUTH_CLIENT_SECRET=
