# Supabase — from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — for Whisper transcription and GPT-4o feedback
OPENAI_API_KEY=sk-...

# Resend — for access request approval/rejection emails
RESEND_API_KEY=re_...

# Admin — the email address that can access /admin
ADMIN_EMAIL=mickhatzikostas220@gmail.com

# Admin action secret — signs the one-time approve/deny links in admin emails.
# IMPORTANT: set this to a long random string in production. If left unset, a
# public hardcoded fallback is used, which would let anyone forge action links.
ADMIN_ACTION_SECRET=change-me-to-a-long-random-string

# App URL — used in invite links sent via email
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Tribe v2 GPU server — leave empty to use mock data
# Deploy tribe-server/main.py to Modal or RunPod, then set this URL
TRIBE_SERVER_URL=
# Optional auth token for your GPU server
TRIBE_SERVER_SECRET=
